# PostgreSQL 18 Database
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=tai_chinh_cong_doan
DB_USER=finance_admin
DB_PASSWORD=YOUR_STRONG_PASSWORD_HERE

# JWT Secret (tạo chuỗi ngẫu nhiên dài)
JWT_SECRET=your-very-long-random-secret-key-change-this

# Server - API + Frontend chạy chung cổng 3001
PORT=3001
HOST=0.0.0.0

# Allowed origins (các địa chỉ IP được phép truy cập)
ALLOWED_ORIGINS=http://10.24.16.77:3001,http://10.24.16.77,http://localhost:3001,http://localhost:5173

# Proxy mạng (để npm tải package qua proxy)
HTTP_PROXY=http://hn.proxy.vdb:8080
HTTPS_PROXY=http://hn.proxy.vdb:8080
NO_PROXY=localhost,127.0.0.1,10.24.16.77
